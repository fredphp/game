generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ==================== 管理后台用户 (保留) ====================
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==================== 游戏数据统计系统 ====================

/// 每日聚合统计表
model DailyStats {
  id          Int      @id @default(autoincrement())
  date        String   @unique                   // YYYY-MM-DD
  dau         Int      @default(0)               // 日活跃用户数
  mau         Int      @default(0)               // 月活跃用户数
  newUsers    Int      @default(0)               // 新增注册用户
  revenue     Float    @default(0)               // 当日收入(元)
  orders      Int      @default(0)               // 订单数
  payRate     Float    @default(0)               // 付费率(%)
  arpu        Float    @default(0)               // ARPU(元)
  retention1  Float    @default(0)               // 1日留存率(%)
  retention7  Float    @default(0)               // 7日留存率(%)
  retention30 Float    @default(0)               // 30日留存率(%)
  draws       Int      @default(0)               // 抽卡总次数
  battles     Int      @default(0)               // 战斗总次数
  avgOnline   Int      @default(0)               // 平均在线时长(分钟)
  peakOnline  Int      @default(0)               // 峰值在线人数
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/// 抽卡记录表 (抽样记录)
model GachaRecord {
  id         Int      @id @default(autoincrement())
  userId     Int                               // 用户ID
  poolId     Int                               // 卡池ID
  poolName   String   @default("")              // 卡池名称
  heroId     Int      @default(0)               // 抽到武将ID
  heroName   String   @default("")              // 抽到武将名称
  rarity     String   @default("")              // 品质: SSR/SR/R
  drawType   String   @default("single")        // 抽卡类型: single/ten
  pityCount  Int      @default(0)               // 当前保底计数
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([poolId])
  @@index([rarity])
  @@index([createdAt])
}

/// 收入记录表
model RevenueRecord {
  id           Int      @id @default(autoincrement())
  orderNo      String   @unique                 // 订单号
  userId       Int                               // 用户ID
  nickname     String   @default("")              // 用户昵称
  productType  String   @default("")              // 商品类型: diamond/monthly/gift/vip
  productName  String   @default("")              // 商品名称
  amount       Float                              // 金额(元)
  diamond      Int      @default(0)               // 获得钻石
  payMethod    String   @default("")              // 支付方式
  status       Int      @default(0)               // 状态: 0待支付 1已支付 2已发货 3已退款
  paidAt       DateTime?                          // 支付时间
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([productType])
  @@index([status])
  @@index([createdAt])
}

/// 用户活跃日志 (用于计算DAU/MAU)
model UserActiveLog {
  id        Int      @id @default(autoincrement())
  userId    Int                                // 用户ID
  action    String   @default("login")          // 活跃动作: login/battle/gacha/trade
  duration  Int      @default(0)                // 在线时长(秒)
  ip        String   @default("")
  device    String   @default("")
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

/// 留存率记录表 (cohort)
model RetentionRecord {
  id           Int      @id @default(autoincrement())
  cohortDate   String                              // 注册批次日期 YYYY-MM-DD
  cohortSize   Int      @default(0)                 // 该批次注册人数
  day1         Int      @default(0)                 // 次日回访人数
  day3         Int      @default(0)                 // 3日回访人数
  day7         Int      @default(0)                 // 7日回访人数
  day14        Int      @default(0)                 // 14日回访人数
  day30        Int      @default(0)                 // 30日回访人数
  retention1   Float    @default(0)                 // 1日留存率(%)
  retention3   Float    @default(0)                 // 3日留存率(%)
  retention7   Float    @default(0)                 // 7日留存率(%)
  retention14  Float    @default(0)                 // 14日留存率(%)
  retention30  Float    @default(0)                 // 30日留存率(%)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([cohortDate])
}

// ==================== 游戏核心流程系统 ====================

/// 新手引导步骤
model TutorialStep {
  id          Int      @id @default(autoincrement())
  stepOrder   Int                               // 步骤顺序
  stepKey     String   @unique                  // 步骤唯一标识
  title       String                           // 步骤标题
  triggerType String   @default("level")        // 触发类型: level/building/battle/gacha/quest/social
  isRequired  Boolean  @default(true)           // 是否必须完成
  status      Int      @default(1)              // 1=启用 0=禁用
  dialogues    String   @default("[]")           // 对话内容JSON
  rewards      String   @default("{}")           // 奖励JSON
  uiTarget     String   @default("")             // UI指向目标
  description  String   @default("")             // 描述
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

/// 主线章节
model Chapter {
  id           Int      @id @default(autoincrement())
  chapterOrder Int                               // 章节顺序
  title        String                           // 章节标题
  unlockLevel  Int      @default(1)              // 解锁等级
  description  String   @default("")             // 章节描述
  status       Int      @default(1)              // 1=启用 0=禁用
  quests       Quest[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

/// 主线任务
model Quest {
  id          Int      @id @default(autoincrement())
  chapterId   Int                               // 所属章节ID
  questOrder  Int                               // 任务顺序
  title       String                           // 任务标题
  questType   String   @default("story")        // 类型: story/battle/collect/explore/escort/defend
  targetType  String   @default("")             // 目标类型
  targetCount Int      @default(1)              // 目标数量
  energyCost  Int      @default(5)              // 体力消耗
  rewards     String   @default("{}")           // 奖励JSON
  description String   @default("")             // 描述
  status      Int      @default(1)              // 1=启用 0=禁用
  chapter     Chapter  @relation(fields: [chapterId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([chapterId])
}

/// 日常任务
model DailyTask {
  id              Int      @id @default(autoincrement())
  taskKey         String   @unique              // 任务唯一标识
  title           String                         // 任务标题
  taskType        String   @default("battle")   // 类型: battle/gacha/social/guild/resource/growth
  targetCount     Int      @default(1)           // 目标数量
  refreshType     String   @default("daily")     // 刷新类型: daily/weekly
  activityPoints  Int      @default(10)          // 活跃度积分
  sortOrder       Int      @default(0)           // 排序
  status          Int      @default(1)           // 1=启用 0=禁用
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

/// 活跃度里程碑
model ActivityMilestone {
  id              Int      @id @default(autoincrement())
  requiredPoints  Int                               // 所需活跃度
  rewards         String   @default("{}")           // 奖励JSON
  title           String                           // 里程碑标题
  sortOrder       Int      @default(0)              // 排序
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

/// 成就
model Achievement {
  id              Int      @id @default(autoincrement())
  title           String                           // 成就名称
  description     String                           // 成就描述
  category        String   @default("battle")      // 分类: battle/collection/social/development/guild
  conditionType   String                           // 条件类型
  conditionParams String   @default("{}")           // 条件参数JSON
  rewardPoints    Int      @default(10)             // 奖励积分
  isHidden        Boolean  @default(false)           // 是否隐藏
  sortOrder       Int      @default(0)              // 排序
  status          Int      @default(1)              // 1=启用 0=禁用
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

/// 玩家任务进度 (抽样)
model PlayerQuestProgress {
  id              Int      @id @default(autoincrement())
  userId          Int                                // 用户ID
  progressType    String                             // progress_type: tutorial/quest/daily/achievement
  targetId        Int      @default(0)               // 目标ID(步骤/任务/成就ID)
  status          Int      @default(0)               // 0=未开始 1=进行中 2=已完成 3=已领取
  currentValue    Int      @default(0)               // 当前进度值
  completedAt     DateTime?                          // 完成时间
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([progressType])
  @@index([status])
  @@index([createdAt])
}

/// 核心流程日统计
model CoreFlowDailyStats {
  id                    Int      @id @default(autoincrement())
  date                  String   @unique                // YYYY-MM-DD
  // 新手引导
  tutorialStarted       Int      @default(0)             // 开始引导人数
  tutorialCompleted     Int      @default(0)             // 完成引导人数
  tutorialDropStep      Int      @default(0)             // 平均流失步骤
  tutorialCompleteRate  Float    @default(0)             // 引导完成率(%)
  // 主线任务
  questStarted          Int      @default(0)             // 开始主线人数
  questAvgProgress      Float    @default(0)             // 平均主线进度(章节数)
  quest7DayFinishRate   Float    @default(0)             // 新用户7日主线完成率(%)
  // 日常任务
  dailyTaskAvgCount     Float    @default(0)             // 人均每日完成日常数
  dailyTaskFullRate     Float    @default(0)             // 全部完成率(%)
  // 成就
  achievementAvgCount   Float    @default(0)             // 人均解锁成就数
  achievementPopRate    Float    @default(0)             // 最热成就解锁率(%)
  // 综合
  day1WithTutorial      Float    @default(0)             // 完成引导用户1日留存(%)
  day1WithoutTutorial   Float    @default(0)             // 未完成引导用户1日留存(%)
  day7WithQuest         Float    @default(0)             // 推进主线用户7日留存(%)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// ==================== 运营系统 ====================

/// 运营活动
model Activity {
  id          Int            @id @default(autoincrement())
  title       String                               // 活动标题
  description String         @default("")          // 活动描述
  type        String         @default("gacha")      // 类型: gacha/battle/collection/social/limited
  status      String         @default("draft")      // 状态: draft/active/paused/ended
  startTime   String         @default("")          // 开始时间
  endTime     String         @default("")          // 结束时间
  rewards     String         @default("{}")          // 奖励JSON
  tasks       ActivityTask[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

/// 活动任务 (活动下的具体任务项)
model ActivityTask {
  id            Int      @id @default(autoincrement())
  activityId     Int                                // 所属活动ID
  sortOrder     Int      @default(0)                   // 排序
  title         String                              // 任务标题
  description   String   @default("")                 // 任务描述
  taskType      String   @default("collect")         // 类型: collect/battle/gacha/trade/login/social
  targetType    String   @default("")                 // 目标类型: hero/gold/diamond/win/battle_count
  targetCount    Int      @default(1)                   // 目标数量
  targetId      String   @default("")                 // 目标具体ID
  rewards       String   @default("{}")                // 奖励JSON
  status        Int      @default(1)                   // 1=启用 0=禁用
  activity      Activity @relation(fields: [activityId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([activityId])
}

/// 玩家活动进度
model PlayerActivityProgress {
  id            Int      @id @default(autoincrement())
  userId        Int                                // 用户ID
  activityId     Int                                // 活动ID
  taskId        Int      @default(0)                 // 任务ID
  progress      Int      @default(0)                   // 当前进度
  status        Int      @default(0)                   // 0=未开始 1=进行中 2=已领取
  rewards       String   @default("{}")                // 领取的奖励JSON
  completedAt   DateTime?                          // 完成时间
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([activityId])
  @@index([status])
}

/// 战令(Battle Pass)
model BattlePass {
  id            Int                @id @default(autoincrement())
  seasonKey     String             @unique                  // 赛季标识(如 "S2025S3")
  title         String                                     // 赛季标题
  description   String             @default("")           // 赛季描述
  startTime     String                                     // 开始时间
  endTime       String                                     // 结束时间
  price         Int                @default(0)             // 价格(钻石)
  premiumPrice   Int                @default(0)             // 高级版价格(钻石)
  isPremium     Boolean            @default(false)          // 是否高级版
  status        Int                @default(1)             // 1=进行中 0=未开始 2=已结束
  totalExp       Int                @default(0)             // 总经验值(满级经验)
  participants   Int                @default(0)             // 参与人数
  premiumUsers   Int                @default(0)             // 购买高级版人数
  levels        BattlePassLevel[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
}

/// 战令等级奖励
model BattlePassLevel {
  id            Int      @id @default(autoincrement())
  passId        Int                                // 所属战令ID
  level         Int                                // 等级 (1-50)
  requiredExp    Int                                // 所需经验
  freeRewards    String   @default("{}")              // 免费奖励JSON
  premiumRewards String   @default("{}")              // 高级奖励JSON
  title         String   @default("")                 // 等级标题
  iconType      String   @default("chest")              // 图标类型
  battlePass    BattlePass @relation(fields: [passId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([passId])
  @@index([passId, level])
}

/// 玩家战令进度
model PlayerBattlePass {
  id            Int      @id @default(autoincrement())
  userId        Int                                // 用户ID
  passId        Int                                // 战令ID
  isPremium     Boolean  @default(false)              // 是否高级版
  currentLevel   Int      @default(0)                   // 当前等级
  currentExp     Int      @default(0)                   // 当前经验
  totalExpGained Int      @default(0)                   // 累计获得经验
  claimedLevels String   @default("[]")                // 已领取等级JSON数组 [1,2,5]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, passId])
  @@index([userId])
  @@index([passId])
}

/// 限时卡池
model LimitedPool {
  id            Int      @id @default(autoincrement())
  poolKey       String   @unique                  // 卡池唯一标识
  name          String                              // 卡池名称
  type          String   @default("limited")          // 类型: limited/faction/mix/rateup
  description   String   @default("")                 // 卡池描述
  bannerUrl     String   @default("")                 // Banner图片URL
  startTime     String                              // 开始时间
  endTime       String                              // 结束时间
  ssrRate       Float    @default(1.5)               // SSR概率(%)
  srRate        Float    @default(8.5)               // SR概率(%)
  rRate         Float    @default(90.0)              // R概率(%)
  pityCount     Int      @default(50)                  // 软保底
  hardPityCount Int      @default(80)                  // 硬保底
  upHeroId      Int      @default(0)                   // UP英雄ID (0=无UP)
  upRate        Float    @default(0.5)               // UP额外概率(%)
  totalDraws    Int      @default(0)                   // 总抽数
  todayDraws     Int      @default(0)                   // 今日抽数
  status        Int      @default(1)                   // 1=开启 0=关闭
  sort          Int      @default(0)                   // 排序权重
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([type])
  @@index([status])
  @@index([startTime])
}

/// 邮件
model Mail {
  id            Int      @id @default(autoincrement())
  mailUid       String   @unique                  // 邮件唯一ID
  senderType    String   @default("system")          // 发送者类型: system/gm/guild/personal
  senderId      Int      @default(0)                   // 发送者ID
  senderName    String   @default("系统")            // 发送者名称
  receiverId     Int                                // 接收者ID
  category      String   @default("system")          // 分类: system/reward/activity/notification/social/guild
  title         String                              // 邮件标题
  content       String   @default("")                 // 邮件正文
  attachments   String   @default("[]")                // 附件JSON [{type, id, name, count}]
  isRead        Boolean  @default(false)              // 是否已读
  isClaimed     Boolean  @default(false)              // 奖励是否已领取
  isDeleted     Boolean  @default(false)              // 是否已删除(软删)
  expireAt      DateTime?                          // 过期时间
  claimedAt     DateTime?                          // 领取时间
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([receiverId])
  @@index([category])
  @@index([isRead])
  @@index([isDeleted])
  @@index([createdAt])
}

/// 玩家邮件统计
model MailStats {
  id            Int      @id @default(autoincrement())
  userId        Int      @unique                  // 用户ID
  total         Int      @default(0)                   // 总邮件数
  unread        Int      @default(0)                   // 未读数
  rewardPending Int      @default(0)                   // 待领取奖励邮件数
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
}

// ==================== 游戏核心实体 ====================

/// 游戏玩家
model GamePlayer {
  id            Int      @id @default(autoincrement())
  uid           String   @unique                    // 玩家唯一ID (如 UID10001)
  nickname      String                              // 昵称
  level         Int      @default(1)                 // 等级
  vipLevel      Int      @default(0)                 // VIP等级
  power         Int      @default(0)                 // 战力
  gold          Int      @default(0)                 // 金币
  diamond       Int      @default(0)                 // 钻石
  stamina       Int      @default(100)               // 体力
  maxStamina    Int      @default(100)               // 最大体力
  prestige      Int      @default(0)                 // 声望
  exp           Int      @default(0)                 // 经验值
  guildId       Int?                                // 联盟ID
  serverId      Int      @default(1)                 // 服务器ID
  status        Int      @default(1)                 // 1=正常 0=封禁 2=冻结
  lastLoginAt   DateTime?                           // 最后登录
  lastLoginIp   String   @default("")
  registerAt    DateTime @default(now())             // 注册时间
  totalRecharge Int      @default(0)                 // 累计充值(分)
  heroCount     Int      @default(0)                 // 拥有武将数
  battleCount   Int      @default(0)                 // 战斗次数
  winCount      Int      @default(0)                 // 胜利次数
  cityCount     Int      @default(0)                 // 占领城池数
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([guildId])
  @@index([serverId])
  @@index([status])
  @@index([level])
  @@index([power])
}

/// 武将/卡牌表
model Hero {
  id           Int      @id @default(autoincrement())
  heroKey      String   @unique                     // 武将唯一标识
  name         String                               // 武将名称
  title        String   @default("")                 // 称号 (如 "天下无双")
  rarity       String   @default("R")                // 品质: SSR/SR/R
  faction      String   @default("qun")              // 阵营: wei/shu/wu/qun
  type         String   @default("infantry")         // 兵种: infantry/cavalry/archer/strategist
  baseAtk      Int      @default(100)                // 基础攻击
  baseDef      Int      @default(100)                // 基础防御
  baseHp       Int      @default(1000)               // 基础血量
  baseSpeed    Int      @default(20)                 // 基础速度
  growthAtk    Int      @default(5)                  // 攻击成长
  growthDef    Int      @default(3)                  // 防御成长
  growthHp     Int      @default(50)                 // 血量成长
  skillJson    String   @default("[]")               // 技能JSON
  description  String   @default("")                 // 描述
  status       Int      @default(1)                  // 1=启用 0=禁用
  drawCount    Int      @default(0)                  // 被抽次数
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([rarity])
  @@index([faction])
  @@index([type])
  @@index([status])
}

/// 玩家武将(背包)
model PlayerHero {
  id          Int      @id @default(autoincrement())
  playerId    Int                                 // 玩家ID
  heroId      Int                                 // 武将ID
  heroName    String   @default("")                // 冗余: 武将名
  rarity      String   @default("R")               // 冗余: 品质
  starLevel   Int      @default(1)                 // 星级
  level       Int      @default(1)                 // 等级
  exp         Int      @default(0)                 // 经验
  isLocked    Boolean  @default(false)             // 是否锁定
  obtainedAt  String   @default("")                // 获取方式: gacha/shop/reward
  obtainedFrom String  @default("")                // 来源详情
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([playerId])
  @@index([heroId])
  @@index([rarity])
}

/// 常驻卡池
model CardPool {
  id            Int      @id @default(autoincrement())
  name          String                              // 卡池名称
  type          String   @default("normal")         // 类型: normal/limited/faction/start/mix
  typeName      String   @default("常驻")            // 类型显示名
  description   String   @default("")                 // 描述
  status        Int      @default(1)                  // 1=开启 0=关闭
  startTime     String   @default("")                 // 开始时间
  endTime       String   @default("")                 // 结束时间
  ssrRate       Float    @default(2.0)               // SSR概率(%)
  srRate        Float    @default(10.0)              // SR概率(%)
  rRate         Float    @default(88.0)              // R概率(%)
  pityCount     Int      @default(60)                 // 软保底
  hardPityCount Int      @default(80)                 // 硬保底
  upHeroId      Int?                                // UP英雄ID
  upHeroName    String   @default("-")               // UP英雄名
  totalDraws    Int      @default(0)                  // 总抽数
  todayDraws    Int      @default(0)                  // 今日抽数
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([type])
  @@index([status])
}

/// 联盟/公会
model Guild {
  id          Int      @id @default(autoincrement())
  name        String                              // 联盟名称
  leaderId    Int                                 // 盟主ID
  leaderName  String   @default("")                // 盟主名
  memberCount Int      @default(1)                 // 成员数
  maxMembers  Int      @default(50)                // 最大成员数
  level       Int      @default(1)                 // 联盟等级
  exp         Int      @default(0)                 // 联盟经验
  notice      String   @default("")                // 公告
  cityCount   Int      @default(0)                 // 占领城池数
  totalPower  Int      @default(0)                 // 总战力
  rank        Int      @default(0)                 // 排名
  status      Int      @default(1)                 // 1=正常 0=解散
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([leaderId])
  @@index([rank])
  @@index([status])
}

/// 联盟成员
model GuildMember {
  id            Int      @id @default(autoincrement())
  guildId       Int                                 // 联盟ID
  userId        Int                                 // 玩家ID
  nickname      String   @default("")                // 玩家昵称
  level         Int      @default(1)                 // 玩家等级
  power         Int      @default(0)                 // 玩家战力
  role          String   @default("member")          // 角色: leader/vice_leader/elder/member
  contribution  Int      @default(0)                 // 贡献值
  joinAt        DateTime @default(now())             // 加入时间
  lastActiveAt  DateTime @default(now())             // 最后活跃
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([guildId])
  @@index([userId])
  @@unique([guildId, userId])
}

/// 城池
model City {
  id            Int      @id @default(autoincrement())
  name          String                              // 城池名
  x             Int      @default(0)                 // X坐标
  y             Int      @default(0)                 // Y坐标
  level         Int      @default(1)                 // 城池等级
  faction       String   @default("中立")             // 所属阵营
  ownerId       Int?                                // 占领者ID
  ownerName     String   @default("")                // 占领者名
  guildId       Int?                                // 所属联盟ID
  guildName     String   @default("")                // 所属联盟名
  resourceType  String   @default("粮食")            // 资源类型
  resourceLevel Int      @default(1)                 // 资源等级
  defense       Int      @default(1000)              // 防御值
  garrison      Int      @default(0)                 // 驻军数
  status        Int      @default(1)                 // 1=正常 0=废弃
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([ownerId])
  @@index([guildId])
  @@index([faction])
  @@index([level])
}

/// 行军队列
model MarchQueue {
  id          Int      @id @default(autoincrement())
  userId      Int                                 // 玩家ID
  userName    String   @default("")                // 玩家名
  fromCityId  Int                                 // 出发城池
  fromCityName String  @default("")                // 出发城池名
  toCityId    Int                                 // 目标城池
  toCityName  String   @default("")                // 目标城池名
  troops      Int      @default(0)                 // 兵力
  heroName    String   @default("")                // 领队武将
  status      String   @default("marching")        // 状态: marching/arrived/returning/cancelled
  startTime   String   @default("")                // 出发时间
  arriveTime  String   @default("")                // 到达时间
  duration    Int      @default(0)                 // 行军时长(秒)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

/// 订单表
model GameOrder {
  id           Int      @id @default(autoincrement())
  orderNo      String   @unique                    // 订单号
  userId       Int                                 // 玩家ID
  nickname     String   @default("")                // 玩家昵称
  productType  String   @default("diamond")         // 商品类型: diamond/monthly/gift/vip
  productName  String   @default("")                // 商品名称
  amount       Int      @default(0)                 // 金额(分)
  diamond      Int      @default(0)                 // 获得钻石
  bonus        Int      @default(0)                 // 赠送钻石
  status       Int      @default(0)                 // 状态: 0待支付 1已支付 2已发货 3已退款 4已关闭
  statusText   String   @default("待支付")           // 状态文本
  payMethod    String   @default("")                // 支付方式
  tradeNo      String   @default("")                // 第三方交易号
  paidAt       DateTime?                           // 支付时间
  deliveredAt  DateTime?                           // 发货时间
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
  @@index([productType])
  @@index([status])
  @@index([createdAt])
}

/// 系统配置
model GameConfig {
  id          Int      @id @default(autoincrement())
  configKey   String   @unique                    // 配置键
  name        String                              // 配置名
  value       String   @default("")                // 配置值
  type        String   @default("string")          // 类型: string/number/boolean/json
  group       String   @default("global")          // 分组: gacha/map/battle/global/activity/payment/vip/guild
  description String   @default("")                // 描述
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([group])
}

/// 操作日志
model GmLog {
  id          Int      @id @default(autoincrement())
  operatorId  Int                                 // 操作者ID
  operatorName String  @default("")                // 操作者名
  targetId    Int      @default(0)                 // 目标ID
  targetType  String   @default("user")            // 目标类型
  action      String   @default("")                // 操作类型
  detail      String   @default("")                // 操作详情
  ip          String   @default("")                // IP
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([operatorId])
  @@index([action])
  @@index([createdAt])
}
