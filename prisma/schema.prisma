generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ==================== 管理后台用户 (保留) ====================
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==================== 游戏数据统计系统 ====================

/// 每日聚合统计表
model DailyStats {
  id          Int      @id @default(autoincrement())
  date        String   @unique                   // YYYY-MM-DD
  dau         Int      @default(0)               // 日活跃用户数
  mau         Int      @default(0)               // 月活跃用户数
  newUsers    Int      @default(0)               // 新增注册用户
  revenue     Float    @default(0)               // 当日收入(元)
  orders      Int      @default(0)               // 订单数
  payRate     Float    @default(0)               // 付费率(%)
  arpu        Float    @default(0)               // ARPU(元)
  retention1  Float    @default(0)               // 1日留存率(%)
  retention7  Float    @default(0)               // 7日留存率(%)
  retention30 Float    @default(0)               // 30日留存率(%)
  draws       Int      @default(0)               // 抽卡总次数
  battles     Int      @default(0)               // 战斗总次数
  avgOnline   Int      @default(0)               // 平均在线时长(分钟)
  peakOnline  Int      @default(0)               // 峰值在线人数
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/// 抽卡记录表 (抽样记录)
model GachaRecord {
  id         Int      @id @default(autoincrement())
  userId     Int                               // 用户ID
  poolId     Int                               // 卡池ID
  poolName   String   @default("")              // 卡池名称
  heroId     Int      @default(0)               // 抽到武将ID
  heroName   String   @default("")              // 抽到武将名称
  rarity     String   @default("")              // 品质: SSR/SR/R
  drawType   String   @default("single")        // 抽卡类型: single/ten
  pityCount  Int      @default(0)               // 当前保底计数
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([poolId])
  @@index([rarity])
  @@index([createdAt])
}

/// 收入记录表
model RevenueRecord {
  id           Int      @id @default(autoincrement())
  orderNo      String   @unique                 // 订单号
  userId       Int                               // 用户ID
  nickname     String   @default("")              // 用户昵称
  productType  String   @default("")              // 商品类型: diamond/monthly/gift/vip
  productName  String   @default("")              // 商品名称
  amount       Float                              // 金额(元)
  diamond      Int      @default(0)               // 获得钻石
  payMethod    String   @default("")              // 支付方式
  status       Int      @default(0)               // 状态: 0待支付 1已支付 2已发货 3已退款
  paidAt       DateTime?                          // 支付时间
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([productType])
  @@index([status])
  @@index([createdAt])
}

/// 用户活跃日志 (用于计算DAU/MAU)
model UserActiveLog {
  id        Int      @id @default(autoincrement())
  userId    Int                                // 用户ID
  action    String   @default("login")          // 活跃动作: login/battle/gacha/trade
  duration  Int      @default(0)                // 在线时长(秒)
  ip        String   @default("")
  device    String   @default("")
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

/// 留存率记录表 (cohort)
model RetentionRecord {
  id           Int      @id @default(autoincrement())
  cohortDate   String                              // 注册批次日期 YYYY-MM-DD
  cohortSize   Int      @default(0)                 // 该批次注册人数
  day1         Int      @default(0)                 // 次日回访人数
  day3         Int      @default(0)                 // 3日回访人数
  day7         Int      @default(0)                 // 7日回访人数
  day14        Int      @default(0)                 // 14日回访人数
  day30        Int      @default(0)                 // 30日回访人数
  retention1   Float    @default(0)                 // 1日留存率(%)
  retention3   Float    @default(0)                 // 3日留存率(%)
  retention7   Float    @default(0)                 // 7日留存率(%)
  retention14  Float    @default(0)                 // 14日留存率(%)
  retention30  Float    @default(0)                 // 30日留存率(%)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([cohortDate])
}

// ==================== 游戏核心流程系统 ====================

/// 新手引导步骤
model TutorialStep {
  id          Int      @id @default(autoincrement())
  stepOrder   Int                               // 步骤顺序
  stepKey     String   @unique                  // 步骤唯一标识
  title       String                           // 步骤标题
  triggerType String   @default("level")        // 触发类型: level/building/battle/gacha/quest/social
  isRequired  Boolean  @default(true)           // 是否必须完成
  status      Int      @default(1)              // 1=启用 0=禁用
  dialogues    String   @default("[]")           // 对话内容JSON
  rewards      String   @default("{}")           // 奖励JSON
  uiTarget     String   @default("")             // UI指向目标
  description  String   @default("")             // 描述
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

/// 主线章节
model Chapter {
  id           Int      @id @default(autoincrement())
  chapterOrder Int                               // 章节顺序
  title        String                           // 章节标题
  unlockLevel  Int      @default(1)              // 解锁等级
  description  String   @default("")             // 章节描述
  status       Int      @default(1)              // 1=启用 0=禁用
  quests       Quest[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

/// 主线任务
model Quest {
  id          Int      @id @default(autoincrement())
  chapterId   Int                               // 所属章节ID
  questOrder  Int                               // 任务顺序
  title       String                           // 任务标题
  questType   String   @default("story")        // 类型: story/battle/collect/explore/escort/defend
  targetType  String   @default("")             // 目标类型
  targetCount Int      @default(1)              // 目标数量
  energyCost  Int      @default(5)              // 体力消耗
  rewards     String   @default("{}")           // 奖励JSON
  description String   @default("")             // 描述
  status      Int      @default(1)              // 1=启用 0=禁用
  chapter     Chapter  @relation(fields: [chapterId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([chapterId])
}

/// 日常任务
model DailyTask {
  id              Int      @id @default(autoincrement())
  taskKey         String   @unique              // 任务唯一标识
  title           String                         // 任务标题
  taskType        String   @default("battle")   // 类型: battle/gacha/social/guild/resource/growth
  targetCount     Int      @default(1)           // 目标数量
  refreshType     String   @default("daily")     // 刷新类型: daily/weekly
  activityPoints  Int      @default(10)          // 活跃度积分
  sortOrder       Int      @default(0)           // 排序
  status          Int      @default(1)           // 1=启用 0=禁用
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

/// 活跃度里程碑
model ActivityMilestone {
  id              Int      @id @default(autoincrement())
  requiredPoints  Int                               // 所需活跃度
  rewards         String   @default("{}")           // 奖励JSON
  title           String                           // 里程碑标题
  sortOrder       Int      @default(0)              // 排序
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

/// 成就
model Achievement {
  id              Int      @id @default(autoincrement())
  title           String                           // 成就名称
  description     String                           // 成就描述
  category        String   @default("battle")      // 分类: battle/collection/social/development/guild
  conditionType   String                           // 条件类型
  conditionParams String   @default("{}")           // 条件参数JSON
  rewardPoints    Int      @default(10)             // 奖励积分
  isHidden        Boolean  @default(false)           // 是否隐藏
  sortOrder       Int      @default(0)              // 排序
  status          Int      @default(1)              // 1=启用 0=禁用
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

/// 玩家任务进度 (抽样)
model PlayerQuestProgress {
  id              Int      @id @default(autoincrement())
  userId          Int                                // 用户ID
  progressType    String                             // progress_type: tutorial/quest/daily/achievement
  targetId        Int      @default(0)               // 目标ID(步骤/任务/成就ID)
  status          Int      @default(0)               // 0=未开始 1=进行中 2=已完成 3=已领取
  currentValue    Int      @default(0)               // 当前进度值
  completedAt     DateTime?                          // 完成时间
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([progressType])
  @@index([status])
  @@index([createdAt])
}

/// 核心流程日统计
model CoreFlowDailyStats {
  id                    Int      @id @default(autoincrement())
  date                  String   @unique                // YYYY-MM-DD
  // 新手引导
  tutorialStarted       Int      @default(0)             // 开始引导人数
  tutorialCompleted     Int      @default(0)             // 完成引导人数
  tutorialDropStep      Int      @default(0)             // 平均流失步骤
  tutorialCompleteRate  Float    @default(0)             // 引导完成率(%)
  // 主线任务
  questStarted          Int      @default(0)             // 开始主线人数
  questAvgProgress      Float    @default(0)             // 平均主线进度(章节数)
  quest7DayFinishRate   Float    @default(0)             // 新用户7日主线完成率(%)
  // 日常任务
  dailyTaskAvgCount     Float    @default(0)             // 人均每日完成日常数
  dailyTaskFullRate     Float    @default(0)             // 全部完成率(%)
  // 成就
  achievementAvgCount   Float    @default(0)             // 人均解锁成就数
  achievementPopRate    Float    @default(0)             // 最热成就解锁率(%)
  // 综合
  day1WithTutorial      Float    @default(0)             // 完成引导用户1日留存(%)
  day1WithoutTutorial   Float    @default(0)             // 未完成引导用户1日留存(%)
  day7WithQuest         Float    @default(0)             // 推进主线用户7日留存(%)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}
